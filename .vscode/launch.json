{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Debug KVStore Test",
            "type": "cppdbg",
            "request": "launch",
            // "program": "${workspaceFolder}/build/kvstore_client",
            "program": "${workspaceFolder}/build/isolation_test",
            // "program": "${workspaceFolder}/build/lock_test",
            "args": [],
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}",
            "environment": [],
            "externalConsole": false,
            "MIMode": "gdb",
            "setupCommands": [
                {
                    "description": "Enable pretty-printing for gdb",
                    "text": "-enable-pretty-printing",
                    "ignoreFailures": true
                }
            ],
            "preLaunchTask": "Build with CMake",
            "miDebuggerPath": "/usr/bin/gdb",
            "logging": {
                "engineLogging": false,
                "trace": false,
                "traceResponse": false
            }
        },
        {
            "name": "Attach to Process",
            "type": "cppdbg",
            "request": "attach",
            // "program": "${workspaceFolder}/build/lock_test",
            "program": "${workspaceFolder}/build/isolation_test",
            // "program": "${workspaceFolder}/build/kvstore_client",
            "processId": "${command:pickProcess}",
            "MIMode": "gdb"
        }
    ]
}