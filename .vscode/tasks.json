{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Build with CMake",
            "type": "shell",
            "command": "cd ${workspaceFolder}/build && cmake .. && make -j4",
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": ["$gcc"],
            "detail": "CMake 配置并编译项目"
        },
        {
            "label": "Clean Build",
            "type": "shell",
            "command": "rm -rf ${workspaceFolder}/build/* && cd ${workspaceFolder}/build && cmake .. && make -j4",
            "group": "build",
            "problemMatcher": ["$gcc"]
        },
        {
            "label": "Run Tests",
            "type": "shell",
            "command": "${workspaceFolder}/build/kvstore_test",
            "group": "test",
            "dependsOn": ["Build with CMake"]
        }
    ]
}